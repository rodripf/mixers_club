{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "types": ["chrome", "node", "vitest/globals", "vite/client"]
  },
  "include": ["src/**/*", "vite.config.ts"],
  "exclude": ["tests/**/*"]
}
